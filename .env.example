# ============================================================
# Lumina — Autonomous B2B Financial Reconciliation AI Agent
# Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# --- MongoDB ---
MONGODB_URI=mongodb+srv://burakmizankilic_db_user:w3aCRxdXdXvRfP08@luminacluster.njy7eek.mongodb.net/?appName=LuminaCluster
MONGODB_DB_NAME=lumina_db

# --- Google Cloud / Gemini ---
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-pro

# --- Gemini API Key (use instead of service account during local dev) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Email (SMTP for sending reconciliation emails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@lumina.ai

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-this-secret-key-in-production
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Local ERP Agent ---
ERP_SYNC_API_URL=http://localhost:8000
ERP_SYNC_API_KEY=your-internal-sync-api-key
ERP_POLL_INTERVAL_SECONDS=3600
ERP_SOURCE_TYPE=excel
# Options for ERP_SOURCE_TYPE: excel, csv, sap, logo, mikro
ERP_DATA_PATH=./data/erp_export.xlsx
COMPANY_ID=replace-with-your-company-mongodb-objectid
COUNTERPARTY_ID=replace-with-counterparty-mongodb-objectid
