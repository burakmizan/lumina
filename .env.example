# ============================================================
# Lumina Enterprise — Autonomous B2B Financial Reconciliation AI
# Environment Variables Configuration Template
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to '.env'
# 2. Replace all placeholder values (<...>) with your actual credentials
# 3. NEVER commit the active '.env' file to version control.
# ============================================================

# --- Database Configuration (MongoDB Atlas) ---
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=LuminaCluster
MONGODB_DB_NAME=lumina_db

# --- AI Engine (Google Cloud & Gemini) ---
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-flash-8b

# --- Local Development Authentication ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Mail Server (SMTP for Auto-Dispatch) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_corporate_email@company.com
SMTP_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@lumina.ai

# --- Core Backend Settings ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=generate_a_secure_random_string_for_production
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- ERP Integration Agent ---
ERP_SYNC_API_URL=http://localhost:8000
ERP_SYNC_API_KEY=generate_internal_sync_api_key
ERP_POLL_INTERVAL_SECONDS=3600
ERP_SOURCE_TYPE=excel
# Supported ERP Drivers: excel, csv, sap, logo, mikro
ERP_DATA_PATH=./data/erp_export.xlsx
COMPANY_ID=<your_company_mongodb_objectid>
COUNTERPARTY_ID=<counterparty_mongodb_objectid>